[ req ]
req_extensions = v3_req
distinguished_name = req_distinguished_name
x509_extensions = usr_cert
prompt = no

[ req_distinguished_name ]
C  = {{ csr_req_distinguished_name_C }}
ST = {{ csr_req_distinguished_name_ST }}
L  = {{ csr_req_distinguished_name_L }}
O  = {{ csr_req_distinguished_name_O }}
OU = {{ csr_req_distinguished_name_OU1 }}
OU = {{ csr_req_distinguished_name_OU2 }}
OU = {{ csr_req_distinguished_name_OU3 }}
{% if 'scanners' in group_names %}
CN = {{ ansible_facts['hostname'] }}-nessus{{ csr_req_distinguished_name_domain }}
{% else %}
CN = {{ ansible_facts['hostname'] }}{{ csr_req_distinguished_name_domain }}
{% endif %}

[ v3_req ]
basicConstraints = CA:FALSE
keyUsage = digitalSignature, nonRepudiation, keyEncipherment, dataEncipherment
extendedKeyUsage = serverAuth, clientAuth, codeSigning, emailProtection
subjectAltName = @alt_names

[ usr_cert ]
basicConstraints=CA:FALSE
nsCertType = client, server, email
keyUsage = nonRepudiation, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth, codeSigning, emailProtection
nsComment = "OpenSSL Generated Certificate"
subjectKeyIdentifier=hash
authorityKeyIdentifier=keyid,issuer

[ alt_names ]
DNS.1 = {{ ansible_facts['hostname'] }}{{ csr_req_distinguished_name_domain }}
DNS.2 = {{ ansible_facts['hostname'] }}
{% if 'scanners' in group_names %}
DNS.3 = {{ ansible_facts['hostname'] }}-nessus{{ csr_req_distinguished_name_domain }}
DNS.4 = {{ ansible_facts['hostname'] }}-nessus
{% endif %}
IP.1 = {{  ansible_facts['default_ipv4']['address'] }}

#template v1.0
